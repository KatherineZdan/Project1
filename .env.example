# Copy to .env.local and fill in to switch from simulated to live MLS data.
# Register for CREA DDF® access: https://www.crea.ca/technology/ddf/
DDF_CLIENT_ID=
DDF_CLIENT_SECRET=

# Optional overrides
# DDF_TOKEN_URL=https://identity.crea.ca/connect/token
# DDF_BASE_URL=https://ddfapi.realtor.ca
# DDF_FILTER=StandardStatus eq 'Active' and StateOrProvince eq 'ON' and PropertySubType eq 'Apartment'
# DDF_MAX_PAGES=25

# Background sync cadence (default 30 minutes)
# REFRESH_INTERVAL_MS=1800000
